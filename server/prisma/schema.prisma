// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  name              String
  role              Role      @default(CLIENT)
  projects          Project[]
  isIDVerified      Boolean   @default(false)
  isPaymentVerified Boolean   @default(false)
  rating            Int       @default(0)
  messages          Message[]
}

model Project {
  id          Int          @id @default(autoincrement())
  client      User         @relation(fields: [clientID], references: [id])
  clientID    Int
  projectType ProjectType?
  tasks       Task[]
  invoices    Invoice[]
  messages    Message[]
  files       File[]
  createdAt   DateTime     @default(now())
}

model Task {
  id          Int      @id @default(autoincrement())
  task        Project  @relation(fields: [projectID], references: [id])
  projectID   Int
  startDate   DateTime @default(now())
  dueDate     DateTime
  taskPayment Float
}

model Invoice {
  id        Int          @id @default(autoincrement())
  createdAt DateTime     @default(now())
  dueDate   DateTime
  project   Project      @relation(fields: [serviceID], references: [id])
  serviceID Int
  amount    Float
  state     InvoiceState
}

model Message {
  id        Int      @id @default(autoincrement())
  project   Project  @relation(fields: [projectID], references: [id])
  user      User     @relation(fields: [senderID], references: [id])
  senderID  Int
  projectID Int
  content   String
  createdAt DateTime @default(now())
}

model File {
  id        Int      @id @default(autoincrement())
  project   Project  @relation(fields: [projectID], references: [id])
  projectID Int
  url       String
  name      String
  createdAt DateTime @default(now())
}

enum Role {
  CLIENT
  FREELANCER
}

enum ProjectType {
  ONE_TIME
  MILESTONES
}

enum InvoiceState {
  PAID
  PENDING
  OVERDUE
}
